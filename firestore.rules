rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Helper function to check if user is the owner of the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users collection rules
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Projects collection rules
    match /projects/{projectId} {
      // Admins have full access
      allow read, write: if isAdmin();
      
      // Allow reading projects for both 'clientId' and 'customerId' to maintain compatibility
      allow read: if request.auth != null && (
        resource == null || 
        resource.data.clientId == request.auth.uid || 
        resource.data.customerId == request.auth.uid
      );
        
      // Allow updates for clients to interact with designs/assets
      allow update: if request.auth != null && (
        resource.data.clientId == request.auth.uid || 
        resource.data.customerId == request.auth.uid
      );
    }

    // Invoices collection rules
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null && (
        resource.data.clientId == request.auth.uid || 
        resource.data.customerId == request.auth.uid
      );
      allow write: if isAdmin();
    }
  }
}
