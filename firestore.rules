rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Helper function to check if user is the owner of the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users collection rules
    match /users/{userId} {
      // Clients can read and update their own profile (essential for onboarding)
      // Admins can manage all user profiles
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Allow initial creation during sign-up
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Projects collection rules
    match /projects/{projectId} {
      // Admins have full control (create, read, update, delete)
      allow read, write: if isAdmin();
      
      // Clients can view and update projects where they are the assigned client
      // We use 'clientId' as the identifier in the project document
      allow read: if request.auth != null && 
        (resource == null || resource.data.clientId == request.auth.uid);
        
      allow update: if request.auth != null && 
        resource.data.clientId == request.auth.uid;
    }

    // Invoices collection rules
    match /invoices/{invoiceId} {
      // Admins have full control
      allow read, write: if isAdmin();
      
      // Clients can only read invoices assigned to them
      allow read: if request.auth != null && 
        resource.data.clientId == request.auth.uid;
        
      // Clients should not be able to update or delete invoices
      allow write: if isAdmin();
    }
  }
}
